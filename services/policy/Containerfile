FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml /app/
RUN pip install --no-cache-dir \
    "fastapi==0.115.4" \
    "uvicorn[standard]==0.32.0" \
    "httpx==0.27.2" \
    "pydantic==2.9.2"

COPY src /app/src

ENV OPA_URL=http://opa:8181
EXPOSE 8002
CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8002"]
