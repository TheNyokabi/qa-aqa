# mitmproxy-based forward proxy with per-sandbox URL allow-list enforcement.
FROM mitmproxy/mitmproxy:11.0.1

# Default base image runs as `mitmproxy` user. Our addon needs read access
# to /tmp/proxy-allowlists which is bind-mounted from runner-service.
# Run as root to sidestep UID-mapping issues during dev — same trade-off as
# the rest of D1.2's sandbox containers.
USER root

COPY src /app/src

# mitmproxy CA cert is stored at /home/mitmproxy/.mitmproxy by default.
# Persist via the mitm-ca named volume mounted there.

EXPOSE 8080 8081
ENTRYPOINT ["mitmdump", "-s", "/app/src/addon.py", \
            "--listen-port", "8080", \
            "--set", "block_global=false", \
            "--set", "stream_large_bodies=10m"]
