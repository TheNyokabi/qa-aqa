FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml /app/
RUN pip install --no-cache-dir \
    "fastapi==0.115.4" \
    "uvicorn[standard]==0.32.0" \
    "pydantic==2.9.2" \
    "asyncpg==0.29.0" \
    "pyyaml==6.0.2"

COPY src /app/src
COPY seed /app/seed

ENV PGHOST=postgres \
    PGPORT=5432 \
    PGUSER=app \
    PGDATABASE=app \
    SEED_DIR=/app/seed
EXPOSE 8003
CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8003"]
